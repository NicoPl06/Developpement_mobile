<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/fragment_request.xml — REMPLACER L'EXISTANT -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/black"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/My_notifs"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_notif_count"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/badge_ecocoin"
            android:gravity="center"
            android:text="@string/zero"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="#F0F0F0">

        <Button
            android:id="@+id/btn_tab_notifs"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/notifications"
            android:textSize="13sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/black"
            style="?android:attr/borderlessButtonStyle"/>

        <Button
            android:id="@+id/btn_tab_requests"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/demands"
            android:textSize="13sp"
            android:textColor="#888888"
            android:backgroundTint="#F0F0F0"
            style="?android:attr/borderlessButtonStyle"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_notifications"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        android:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_requests"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/ll_empty_notif"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/logo_cloche" android:textSize="48sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/zero_notif"
            android:textColor="@color/gris" android:textSize="16sp"
            android:layout_marginTop="8dp" />
    </LinearLayout>
</LinearLayout>