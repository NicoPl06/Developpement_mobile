<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/fragment_calendar.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- En-tête éco-coins -->
    <LinearLayout
        android:id="@+id/header_ecocoins"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/black"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/calendar_of_consommation"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Badge éco-coins -->
        <LinearLayout
            android:id="@+id/ll_ecocoins_badge"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/badge_ecocoin"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/logo_eco_coins"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_ecocoins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/zero_eco_coins"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Légende -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal">

        <View
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@drawable/circle_green" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/_0_30"
            android:textSize="11sp"
            android:textColor="?attr/colorOnSurface" />

        <View
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@drawable/circle_orange" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/_30_70"
            android:textSize="11sp"
            android:textColor="?attr/colorOnSurface" />

        <View
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@drawable/circle_red" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/_70_100"
            android:textSize="11sp"
            android:textColor="?attr/colorOnSurface" />
    </LinearLayout>

    <!-- Sélecteur de jour (scroll horizontal) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <LinearLayout
            android:id="@+id/ll_day_selector"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />
    </HorizontalScrollView>

    <!-- Séparateur -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE" />

    <!-- Liste des créneaux -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_slots"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false" />

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progressbar_calendar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</LinearLayout>