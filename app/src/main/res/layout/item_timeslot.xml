<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/item_timeslot.xml -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Barre de couleur à gauche -->
        <View
            android:id="@+id/view_color_bar"
            android:layout_width="5dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/rounded_bar" />

        <!-- Heure -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_slot_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:text="08:00 – 09:00" />

            <TextView
                android:id="@+id/tv_slot_load"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/gris"
                android:text="Charge : 0 %" />
        </LinearLayout>

        <!-- ProgressBar charge -->
        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="10dp">

            <ProgressBar
                android:id="@+id/pb_slot"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0" />

            <TextView
                android:id="@+id/tv_slot_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/gris"
                android:layout_gravity="end"
                android:text="0 %" />
        </LinearLayout>

        <!-- Bouton réserver -->
        <Button
            android:id="@+id/btn_book"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Réserver"
            android:textSize="12sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:cornerRadius="18dp"
            android:backgroundTint="@color/black" />
    </LinearLayout>
</androidx.cardview.widget.CardView>