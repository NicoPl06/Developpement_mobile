<?xml version="1.0" encoding="utf-8"?>
<!-- res/layout/nav_header.xml -->
<!-- La couleur de fond est définie en dur ici mais sera écrasée dynamiquement
     par applyAccentColor() dans HabitatActivity_Frag au démarrage -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:background="#228B22"
    android:gravity="bottom"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:text="PowerHome"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <TextView
        android:text="Gestion des habitats"
        android:textColor="#AADCAA"
        android:textSize="13sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp" />

</LinearLayout>